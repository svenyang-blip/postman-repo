  "item": [
    {
      "name": "00 GET /categories（Wiki）",
      "description": "`CategoryController#listCategories`：无参；`marketCount` 为可交易事件数语义。",
      "item": [
        {
          "name": "正常：无 query",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('ret_code 为 0', () => pm.expect(body.ret_code).to.eql(0));",
                  "pm.test('result 含 tree 数组', () => {",
                  "  pm.expect(body.result).to.have.property('tree');",
                  "  pm.expect(body.result.tree).to.be.an('array');",
                  "});",
                  "function walk(nodes, fn) { (nodes || []).forEach(n => { fn(n); walk(n.children, fn); }); }",
                  "const tree = body.result.tree;",
                  "pm.test('节点含 id / name（有数据时）', () => {",
                  "  if (!tree.length) return;",
                  "  walk(tree, (n) => { pm.expect(n).to.have.property('id'); pm.expect(n).to.have.property('name'); });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": "{{baseUrl}}/ce/pm/v1/api/categories"
          }
        },
        {
          "name": "边界：多余 query 仍成功",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('ret_code 为 0', () => pm.expect(body.ret_code).to.eql(0));",
                  "pm.test('result.tree 为数组', () => pm.expect(body.result.tree).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": {
              "raw": "{{baseUrl}}/ce/pm/v1/api/categories?junk=1&foo=bar",
              "host": ["{{baseUrl}}"],
              "path": ["ce", "pm", "v1", "api", "categories"],
              "query": [
                { "key": "junk", "value": "1" },
                { "key": "foo", "value": "bar" }
              ]
            }
          }
        }
      ]
    },
