    {
      "name": "05 Wiki · event/list 边界与异常",
      "description": "技术方案 §4：多选、文档示例 `categoryIds` 逗号、非法 `categoryId` 字符串、极大 page、未支持 locale。",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const n = pm.info.requestName || '';",
              "if (n.indexOf('绑定失败') !== -1 || n.indexOf('10001') !== -1) return;",
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('ret_code 为 0', () => pm.expect(body.ret_code).to.eql(0));",
              "pm.test('分页结构', () => pm.expect(body.result.list).to.be.an('array'));"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "文档示例：categoryIds 逗号分隔单参数",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json().result;",
                  "pm.test('逗号多选仍返回合法分页', () => {",
                  "  pm.expect(r.page).to.eql(1);",
                  "  pm.expect(r.list.length).to.be.at.most(5);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": {
              "raw": "{{baseUrl}}/ce/pm/v1/api/event/list?categoryIds={{categoryId}},303&page=1&pageSize=5&eventStatus=TRADABLE&sortBy=START_TIME_ASC",
              "host": ["{{baseUrl}}"],
              "path": ["ce", "pm", "v1", "api", "event", "list"],
