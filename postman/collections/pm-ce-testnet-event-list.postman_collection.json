{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-pm-event-list-demo",
    "name": "PM CE · testnet · event/list",
    "description": "prediction-market `GET /ce/pm/v1/api/event/list` 较完整用例（`EventController` + `MarketListReq`）。\n\n覆盖：分页与默认值、`eventStatus` / `sortBy`、热门、locale、多选 `categoryIds`；匿名可访问。\n\n变量：`baseUrl`、`categoryId`（默认 30101，可按环境改）。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api2-testnet.zoomex.com" },
    { "key": "categoryId", "value": "30101", "description": "测试用分类；无数据时可改为 `/categories` 返回的叶子 id。" }
  ],
  "item": [
    {
      "name": "01 基础与分页",
      "description": "`MarketListReq`：`page`/`pageSize` 规整（`effectivePage`、`effectivePageSize`，最大 50）。",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('ret_code 为 0', () => pm.expect(body.ret_code).to.eql(0));",
              "pm.test('result 含分页字段', () => {",
              "  const r = body.result;",
              "  pm.expect(r).to.have.keys('page', 'pageSize', 'total', 'list');",
              "  pm.expect(r.list).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "最小参数（不限分类）",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json().result;",
                  "pm.test('默认每页条数不超过 50', () => pm.expect(r.pageSize).to.be.at.most(50));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": "{{baseUrl}}/ce/pm/v1/api/event/list?page=1"
          }
        },
        {
          "name": "指定分类 + 小分页",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json().result;",
                  "pm.test('pageSize 与请求一致', () => pm.expect(r.pageSize).to.eql(5));",
                  "pm.test('page 为 1', () => pm.expect(r.page).to.eql(1));",
                  "pm.test('列表项结构（有数据时）', () => {",
                  "  if (r.list.length === 0) return;",
                  "  const e = r.list[0];",
                  "  pm.expect(e).to.have.property('id');",
                  "  pm.expect(e.id).to.be.a('string');",
                  "  pm.expect(e).to.have.property('title');",
                  "  pm.expect(e).to.have.property('markets');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": {
              "raw": "{{baseUrl}}/ce/pm/v1/api/event/list?categoryId={{categoryId}}&page=1&pageSize=5",
              "host": ["{{baseUrl}}"],
              "path": ["ce", "pm", "v1", "api", "event", "list"],
              "query": [
                { "key": "categoryId", "value": "{{categoryId}}" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "pageSize 超过上限应截断为 50",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json().result;",
                  "pm.test('pageSize 不超过 MAX(50)', () => pm.expect(r.pageSize).to.eql(50));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": {
              "raw": "{{baseUrl}}/ce/pm/v1/api/event/list?categoryId={{categoryId}}&page=1&pageSize=200",
              "host": ["{{baseUrl}}"],
              "path": ["ce", "pm", "v1", "api", "event", "list"],
              "query": [
                { "key": "categoryId", "value": "{{categoryId}}" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "200" }
              ]
            }
          }
        },
        {
          "name": "page 小于 1 时回退为第 1 页",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json().result;",
                  "pm.test('effectivePage 为 1', () => pm.expect(r.page).to.eql(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": {
              "raw": "{{baseUrl}}/ce/pm/v1/api/event/list?categoryId={{categoryId}}&page=0&pageSize=5",
              "host": ["{{baseUrl}}"],
              "path": ["ce", "pm", "v1", "api", "event", "list"],
              "query": [
                { "key": "categoryId", "value": "{{categoryId}}" },
                { "key": "page", "value": "0" },
                { "key": "pageSize", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "pageSize 非法时回退默认 20",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json().result;",
                  "pm.test('effectivePageSize 为默认 20', () => pm.expect(r.pageSize).to.eql(20));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": {
              "raw": "{{baseUrl}}/ce/pm/v1/api/event/list?categoryId={{categoryId}}&page=1&pageSize=0",
              "host": ["{{baseUrl}}"],
              "path": ["ce", "pm", "v1", "api", "event", "list"],
              "query": [
                { "key": "categoryId", "value": "{{categoryId}}" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "0" }
              ]
            }
          }
        }
      ]
    },
