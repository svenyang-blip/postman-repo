    {
      "name": "04 响应契约",
      "description": "校验 `Content-Type` 与顶层 JSON 字段命名（`ret_code` snake_case）。",
      "item": [
        {
          "name": "JSON 字段与 Content-Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type 含 json', () =>",
                  "  pm.expect(pm.response.headers.get('Content-Type') || '').to.match(/json/i));",
                  "const body = pm.response.json();",
                  "pm.test('Responses 壳字段（含 ext_code）', () => {",
                  "  pm.expect(body).to.include.keys('ret_code', 'ret_msg', 'result', 'time_now', 'ext_code');",
                  "});",
                  "pm.test('ret_code 为 0', () => pm.expect(body.ret_code).to.eql(0));",
                  "const r = body.result;",
                  "pm.test('total 为非负整数', () => {",
                  "  pm.expect(r.total).to.be.a('number');",
                  "  pm.expect(r.total).to.be.at.least(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": {
              "raw": "{{baseUrl}}/ce/pm/v1/api/event/list?categoryId={{categoryId}}&page=1&pageSize=5",
              "host": ["{{baseUrl}}"],
              "path": ["ce", "pm", "v1", "api", "event", "list"],
              "query": [
                { "key": "categoryId", "value": "{{categoryId}}" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "5" }
