          "name": "B01 list · 默认分页壳",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json().result;",
                  "pm.test('分页壳 page/pageSize/total/list', () => {",
                  "  pm.expect(r).to.have.keys('page', 'pageSize', 'total', 'list');",
                  "  pm.expect(r.list).to.be.an('array');",
                  "});",
                  "pm.test('列表模式 markets[].rules 为 null（有数据时）', () => {",
                  "  r.list.forEach((e) => (e.markets || []).forEach((m) => pm.expect(m.rules).to.eql(null)));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/ce/pm/v1/api/event/list?page=1&pageSize=20"
          }
        },
        {
          "name": "B02 list · updown 叠加字段",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const list = pm.response.json().result.list || [];",
                  "const updown = list.filter((e) => e.instantProductId != null && Number(e.instantProductId) > 0);",
                  "pm.test('updown 事件含 instantProductId', () => {",
                  "  if (!updown.length) {",
                  "    pm.expect(list.length, '当前无 updown 数据，跳过字段断言').to.be.at.least(0);",
