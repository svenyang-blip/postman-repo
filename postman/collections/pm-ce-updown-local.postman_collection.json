                  "}",
                  "pm.test('updown 详情叠加字段', () => {",
                  "  pm.expect(e.instantProductId).to.be.above(0);",
                  "  if (e.windowLabel != null) pm.expect(e.windowLabel).to.be.a('string');",
                  "  if (e.windowStart != null) pm.expect(e.windowStart).to.be.a('string');",
                  "  if (e.windowEnd != null) pm.expect(e.windowEnd).to.be.a('string');",
                  "  if (e.phase != null) {",
                  "    pm.expect(['Scheduled', 'Open', 'Locked', 'Resolving', 'Resolved', 'Suspended']).to.include(e.phase);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/ce/pm/v1/api/event?eventId={{sourceEventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ce", "pm", "v1", "api", "event"],
              "query": [{ "key": "eventId", "value": "{{sourceEventId}}" }]
            }
          }
        }
