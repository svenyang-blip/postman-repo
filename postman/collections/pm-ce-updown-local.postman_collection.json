        {
          "name": "B05 detail · updown 叠加字段",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('sourceEventId')) pm.execution.skipRequest('无 sourceEventId');"
                ]
