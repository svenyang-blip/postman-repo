            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const e = pm.response.json().result;",
                  "if (!(e.instantProductId != null && Number(e.instantProductId) > 0)) {",
                  "  pm.test('非 updown 详情，跳过叠加字段', () => pm.expect(true).to.eql(true));",
