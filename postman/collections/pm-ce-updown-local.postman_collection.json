{
  "info": {
    "_postman_id": "f6a7b8c9-d0e1-2345-f678-pm-ce-updown-local",
    "name": "PM CE · UpdownEventController · local",
    "description": "用户端 `UpdownEventController`（`/ce/pm/v1/api/event/updown`）本地契约测试，并回归 `GET /event/list` 与 `GET /event` 详情。\n\n**源码**：`prediction-serv` `UpdownEventController` / `EventController`。\n\n**本地前置**：`prediction-serv` 以 `spring.profiles.active=dev` 启动（`application-dev.yaml` 已放通 CE 读接口匿名访问）；或在环境变量填入浏览器 `ceCookie`。\n\n**运行**：`npm run pm:ce-updown:local`\n\n**顺序**：先跑 `00 Setup`；`[err]` 为预期失败用例。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "seriesSlug", "value": "btc-up-or-down-5m" },
    { "key": "categoryId", "value": "" },
    { "key": "instantProductId", "value": "" },
    { "key": "updownEventId", "value": "" },
    { "key": "sourceEventId", "value": "" },
    { "key": "anchorEventId", "value": "" },
    { "key": "fakeInstantProductId", "value": "999999999" },
    { "key": "fakeEventId", "value": "999999999" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.request.headers.has('lang')) {",
          "  pm.request.headers.upsert({ key: 'lang', value: 'zh-Hant' });",
          "}",
          "const cookie = (pm.environment.get('ceCookie') || pm.collectionVariables.get('ceCookie') || '').trim();",
          "if (cookie) {",
          "  pm.request.headers.upsert({ key: 'Cookie', value: cookie });",
          "}",
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json, text/plain, */*' });"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const name = pm.info.requestName || '';",
          "if (name.indexOf('[err]') === 0) return;",
          "const body = pm.response.json();",
          "if (body && body.ret_code === 10007) {",
          "  pm.test('未登录（请 dev profile 启动或配置 ceCookie）', () => {",
          "    pm.expect.fail('ret_code=10007 Please login first');",
          "  });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 Setup",
      "description": "解析 categoryId、updown 事件上下文，供后续用例复用。",
      "item": [
        {
          "name": "S01 拉取分类树并写入 categoryId",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('ret_code 为 0', () => pm.expect(body.ret_code).to.eql(0));",
                  "function walk(nodes, fn) { (nodes || []).forEach((n) => { fn(n); walk(n.children, fn); }); }",
                  "function pickLeafId(tree) {",
                  "  let prefer = null, any = null;",
                  "  walk(tree, (n) => {",
                  "    if (!n.isLeaf || n.id == null) return;",
                  "    any = String(n.id);",
                  "    if ((n.marketCount == null || n.marketCount > 0) && !prefer) prefer = String(n.id);",
                  "  });",
                  "  return prefer || any;",
                  "}",
                  "const picked = pickLeafId(body.result.tree);",
                  "if (picked) {",
                  "  pm.collectionVariables.set('categoryId', picked);",
                  "  pm.test('已写入 categoryId=' + picked, () => pm.expect(picked).to.match(/^\\d+$/));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": "{{baseUrl}}/ce/pm/v1/api/categories"
          }
        },
        {
          "name": "S02 从 event/list 解析 updown 上下文",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('ret_code 为 0', () => pm.expect(body.ret_code).to.eql(0));",
                  "const list = (body.result && body.result.list) || [];",
                  "function isUpdown(e) { return e && e.instantProductId != null && Number(e.instantProductId) > 0; }",
                  "let hit = list.find(isUpdown);",
                  "if (!hit) {",
                  "  const cat = pm.collectionVariables.get('categoryId');",
                  "  pm.test('当前页无 updown 事件（后续 updown 正向用例可能跳过）', () => {",
                  "    pm.expect(list.length, 'list 可为空或无非即时产品事件').to.be.at.least(0);",
                  "  });",
                  "} else {",
                  "  pm.collectionVariables.set('instantProductId', String(hit.instantProductId));",
                  "  pm.collectionVariables.set('sourceEventId', String(hit.id));",
                  "  if (hit.categoryId != null) pm.collectionVariables.set('categoryId', String(hit.categoryId));",
                  "  pm.test('已写入 instantProductId / sourceEventId', () => {",
                  "    pm.expect(pm.collectionVariables.get('instantProductId')).to.match(/^\\d+$/);",
                  "    pm.expect(pm.collectionVariables.get('sourceEventId')).to.be.ok;",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": {
              "raw": "{{baseUrl}}/ce/pm/v1/api/event/list?page=1&pageSize=100&eventStatus=ALL&sortBy=START_TIME_DESC",
              "host": ["{{baseUrl}}"],
              "path": ["ce", "pm", "v1", "api", "event", "list"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "100" },
                { "key": "eventStatus", "value": "ALL" },
                { "key": "sortBy", "value": "START_TIME_DESC" }
              ]
            }
          }
        },
        {
          "name": "S03 windows(seriesSlug) 写入 updownEventId / anchorEventId",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('ret_code 为 0', () => pm.expect(body.ret_code).to.eql(0));",
                  "const r = body.result || {};",
                  "pm.test('result 含 current/past/next', () => {",
                  "  pm.expect(r).to.have.keys('current', 'past', 'next');",
                  "  pm.expect(r.past).to.be.an('array');",
                  "  pm.expect(r.next).to.be.an('array');",
                  "});",
                  "if (r.current && r.current.eventId != null) {",
                  "  pm.collectionVariables.set('updownEventId', String(r.current.eventId));",
                  "}",
                  "if (r.past && r.past.length && r.past[0].eventId != null) {",
                  "  pm.collectionVariables.set('anchorEventId', String(r.past[0].eventId));",
                  "}",
                  "const pid = pm.collectionVariables.get('instantProductId');",
                  "if (!pid && body.result && body.result.current) {",
                  "  /* seriesSlug 路径不返回 productId，保留 S02 结果 */",
                  "}",
                  "pm.test('已尝试写入 updownEventId', () => {",
                  "  const eid = pm.collectionVariables.get('updownEventId');",
                  "  if (r.current) pm.expect(eid, 'current.eventId').to.match(/^\\d+$/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "lang", "value": "zh-Hant" }],
            "url": {
              "raw": "{{baseUrl}}/ce/pm/v1/api/event/updown/windows?seriesSlug={{seriesSlug}}",
              "host": ["{{baseUrl}}"],
              "path": ["ce", "pm", "v1", "api", "event", "updown", "windows"],
              "query": [{ "key": "seriesSlug", "value": "{{seriesSlug}}" }]
            }
          }
        }
      ]
    },
